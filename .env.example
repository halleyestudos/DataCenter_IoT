# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Simulador (60 = produção simulada, 5 = testes rápidos)
SIMULATOR_INTERVAL_SECONDS=5
SENSOR_ID=SENSOR-001
MISSING_DATA_PROB=0.08
OUTLIER_PROB=0.05

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-super-secret-auth-token
INFLUXDB_ORG=ufjf
INFLUXDB_BUCKET=datacenter

# Pipeline
PIPELINE_WINDOW_SIZE=5
Z_SCORE_THRESHOLD=2.5
ROLLING_WINDOW=5

# NetBox (opcional — use mock=true para desenvolvimento offline)
NETBOX_USE_MOCK=true
NETBOX_URL=https://netbox.exemplo.local
NETBOX_TOKEN=seu-token-aqui
